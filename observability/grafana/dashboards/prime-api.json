{
  "title": "Prime API Dashboard",
  "panels": [
    {
      "type": "timeseries",
      "title": "Prime API 2xx/4xx/5xx",
      "targets": [
        {"expr": "sum(rate(go_prime_http_requests_total{status=\"2xx\"}[5m]))", "legendFormat": "2xx"},
        {"expr": "sum(rate(go_prime_http_requests_total{status=\"4xx\"}[5m]))", "legendFormat": "4xx"},
        {"expr": "sum(rate(go_prime_http_requests_total{status=\"5xx\"}[5m]))", "legendFormat": "5xx"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Prime API Latency (p50/p95/p99)",
      "targets": [
        {"expr": "histogram_quantile(0.5, sum(rate(go_prime_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum(rate(go_prime_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, sum(rate(go_prime_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s"
}
